import pandas as pd
ranking = pd.DataFrame({
    "Country": ["Sudan", "Nigeria", "Ethiopia", "Kenya", "Tanzania"],
    "Warming_rate": [0.45, 0.38, 0.32, 0.30, 0.28],
    "Precip_CV": [0.38, 0.35, 0.30, 0.28, 0.25],
    "Extreme_heat_days": [120, 100, 80, 75, 70]
})
ranking["Vulnerability_score"] = ranking["Warming_rate"] + ranking["Precip_CV"] + ranking["Extreme_heat_days"]/100
ranking = ranking.sort_values("Vulnerability_score", ascending=False)
print(ranking)